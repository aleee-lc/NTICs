NODE_ENV=development
PORT=3000

# Supabase - PostgreSQL connection string (Transaction pooler, puerto 6543)
DATABASE_URL=postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase - para autenticacion y storage en el frontend
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
SUPABASE_STORAGE_BUCKET=documentos

# URL publica del frontend (usada en CORS y en links de correo)
APP_URL=http://localhost:4200

# Email - SMTP (Gmail u otro proveedor)
# Usar una App Password de Gmail, no la contrasena normal
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_TIMEOUT_MS=15000
MAIL_FROM=PaperHub <tu-correo@gmail.com>

# Email - Resend (fallback si no hay SMTP configurado)
RESEND_API_KEY=re_TU_RESEND_API_KEY
